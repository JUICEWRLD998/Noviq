{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalEnv": [
    "NODE_ENV",
    "OPENROUTER_API_KEY",
    "DATABASE_URL",
    "HSK_RPC_URL",
    "NEXT_PUBLIC_HSK_RPC_URL",
    "NEXT_PUBLIC_HSK_EXPLORER_URL",
    "NEXT_PUBLIC_HSK_CHAIN_ID"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "out/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {}
  }
}
