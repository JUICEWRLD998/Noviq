{
  "name": "noviq",
  "version": "0.0.0",
  "private": true,
  "description": "Programmable trust for autonomous AI money. Don't trust the agent. Trust the covenant.",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "cleanup-testnet": "node --import tsx scripts/cleanup-testnet.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "turbo": "2.10.4",
    "typescript": "5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "sharp"
    ]
  }
}
