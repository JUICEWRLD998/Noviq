# ─────────────────────────────────────────────────────────────
# Noviq — environment variables (copy to .env, never commit .env)
# ─────────────────────────────────────────────────────────────

# --- Chain (HSK Chain mainnet, chainId 177) ---
HSK_RPC_URL="https://mainnet.hsk.xyz"
NEXT_PUBLIC_HSK_RPC_URL="https://mainnet.hsk.xyz"
NEXT_PUBLIC_HSK_EXPLORER_URL="https://explorer.hsk.xyz"
NEXT_PUBLIC_HSK_CHAIN_ID="177"

# --- AI (Gemini via OpenRouter) ---
# https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# --- Persistence (Postgres — Neon/Supabase) ---
# Pooled endpoint for the app/worker runtime.
DATABASE_URL=""
# Direct (non-pooled) endpoint for drizzle-kit migrations/push (no "-pooler" host).
DATABASE_URL_UNPOOLED=""

# --- Agent session key (relayer holds ONLY this scoped key) ---
# Mainnet agent key funded with HSK for gas. Keep secure.
AGENT_PRIVATE_KEY=""
AGENT_ADDRESS=""

# --- Deployer / agent keys are stored in contracts/.env (gitignored),
#     NOT here. See contracts/.env.example.
